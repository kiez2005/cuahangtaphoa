<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <style>

        :root {
            --blue: #1565c0;
            --blue-light: #e8f0fe;
            --border: #e8eaed;
            --bg: #f1f3f4;
            --text: #202124;
            --text-muted: #5f6368;
            --white: #fff;
            --sidebar-w: 220px;
            --topbar-h: 52px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Be Vietnam Pro',sans-serif;
            background: var(--bg);
            color: var(--text);
            font-size: 14px;
        }

        /* SIDEBAR */

        .sidebar {
            position: fixed;
            left: 0;
            top: 0;
            bottom: 0;
            width: var(--sidebar-w);
            background: white;
            border-right: 1px solid var(--border);
            z-index: 100;
            display: flex;
            flex-direction: column;
        }

        .sidebar-logo {
            height: var(--topbar-h);
            display: flex;
            align-items: center;
            padding: 0 16px;
            border-bottom: 1px solid var(--border);
            gap: 8px;
        }

        .logo-icon {
            width: 28px;
            height: 28px;
            background: var(--blue);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
        }

        .logo-text {
            font-weight: 700;
            color: var(--blue);
        }

        .sidebar-nav {
            padding: 10px 0;
        }

        .nav-section-title {
            font-size: 11px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            padding: 12px 16px 6px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 16px;
            color: var(--text-muted);
            text-decoration: none;
            border-left: 3px solid transparent;
        }

            .nav-item:hover {
                background: var(--blue-light);
                color: var(--blue);
            }

            .nav-item.active {
                background: var(--blue-light);
                color: var(--blue);
                border-left-color: var(--blue);
                font-weight: 600;
            }

        /* TOPBAR */

        .topbar {
            position: fixed;
            left: var(--sidebar-w);
            right: 0;
            top: 0;
            height: var(--topbar-h);
            background: white;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 20px;
            z-index: 99;
        }

        .topbar-title {
            font-size: 16px;
            font-weight: 600;
        }

        .topbar-right {
            margin-left: auto;
            display: flex;
            gap: 10px;
        }

        .topbar-btn {
            height: 32px;
            padding: 0 12px;
            border: 1px solid var(--border);
            border-radius: 6px;
            background: white;
            display: flex;
            align-items: center;
            gap: 6px;
            cursor: pointer;
        }

            .topbar-btn:hover {
                background: var(--bg);
            }

        .topbar-avatar {
            width: 35px;
            height: 35px;
            background: #4CAF50;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            cursor: pointer;
        }

        /* CONTENT */

        .content {
            margin-left: var(--sidebar-w);
            margin-top: var(--topbar-h);
            padding: 20px;
        }

        /* AVATAR MENU */

        .avatar-container {
            position: relative;
        }

        .avatar-menu {
            position: absolute;
            right: 0;
            top: 45px;
            width: 200px;
            background: white;
            border: 1px solid #ddd;
            border-radius: 6px;
            box-shadow: 0 2px 10px rgba(0,0,0,.15);
            display: none;
        }

        .menu-item {
            padding: 10px;
            cursor: pointer;
            border-bottom: 1px solid #eee;
        }

            .menu-item:hover {
                background: #f5f5f5;
            }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <aside class="sidebar">

        <div class="sidebar-logo">
            <div class="logo-icon">C</div>
            <span class="logo-text">CuaHang</span>
        </div>

        <nav class="sidebar-nav">

            <div class="nav-section-title">Tổng quan</div>
            <a class="nav-item" href="/Dashboard"><i class="bi bi-grid-1x2"></i> Tổng quan</a>

            <div class="nav-section-title">Bán hàng</div>
            <a class="nav-item" href="/BanHang"><i class="bi bi-bag"></i> Bán hàng</a>
            <a class="nav-item" href="#"><i class="bi bi-receipt"></i> Hóa đơn</a>

            <div class="nav-section-title">Kho hàng</div>
            <a class="nav-item" href="/SanPham"><i class="bi bi-box-seam"></i> Hàng hóa</a>
            <a class="nav-item" href="#"><i class="bi bi-truck"></i> Nhập hàng</a>

            <div class="nav-section-title">Danh mục</div>
            <a class="nav-item" href="#"><i class="bi bi-people"></i> Nhà cung cấp</a>
            <a class="nav-item" href="/NhanVien"><i class="bi bi-person-badge"></i> Nhân viên</a>

            <div class="nav-section-title">Báo cáo</div>
            <a class="nav-item" href="#"><i class="bi bi-bar-chart-line"></i> Doanh thu</a>
        </nav>

    </aside>


    <!-- TOPBAR -->
    <header class="topbar">

        <span class="topbar-title">@ViewBag.Title</span>

        <div class="topbar-right">

            <button class="topbar-btn">
                <i class="bi bi-bell"></i>
            </button>

            <div class="avatar-container">

                <div class="topbar-avatar" onclick="toggleMenu()">A</div>

                <div class="avatar-menu" id="avatarMenu">

                    <div class="menu-item">
                        Thông tin cá nhân
                    </div>

                    <div class="menu-item" onclick="location.href='@Url.Action("Logout","Login")'">
                        Đăng xuất
                    </div>

                </div>

            </div>

        </div>

    </header>


    <!-- NỘI DUNG -->
    <div class="content">
        @RenderBody()
    </div>


    <script>

        function toggleMenu() {
            const menu = document.getElementById("avatarMenu");
            menu.style.display = menu.style.display === "block" ? "none" : "block";
        }

        document.addEventListener("click", function (e) {

            const avatar = document.querySelector(".topbar-avatar");
            const menu = document.getElementById("avatarMenu");

            if (!avatar.contains(e.target) && !menu.contains(e.target)) {
                menu.style.display = "none";
            }

        });

    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>