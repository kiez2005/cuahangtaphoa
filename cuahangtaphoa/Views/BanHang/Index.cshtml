@{
    ViewBag.Title = "Bán hàng";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>POS - Bán hàng</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        :root {
            --blue: #1565c0;
            --blue-dark: #0d47a1;
            --border: #e4e7ec;
            --bg: #eef0f3;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Be Vietnam Pro', sans-serif;
            background: var(--bg);
            font-size: 14px;
            overflow: hidden;
        }

        /* ===== TOPBAR ===== */
        .pos-topbar {
            height: 50px;
            background: var(--blue);
            display: flex;
            align-items: center;
            padding: 0 10px;
            gap: 8px;
            color: white;
        }

        .pos-search {
            position: relative;
            display: flex;
            align-items: center;
            background: white;
            border-radius: 6px;
            height: 34px;
            width: 320px;
            padding: 0 10px;
            gap: 6px;
        }

            .pos-search input {
                border: none;
                outline: none;
                width: 100%;
                font-size: 13px;
            }

        .kbd {
            font-size: 11px;
            background: #f1f3f5;
            padding: 2px 6px;
            border-radius: 4px;
        }

        .icon-btn {
            width: 34px;
            height: 34px;
            border: none;
            background: rgba(255,255,255,.2);
            border-radius: 6px;
            color: white;
            cursor: pointer;
        }

        .topbar-right {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .nav-icon {
            border: none;
            background: none;
            color: white;
            font-size: 18px;
            cursor: pointer;
        }

        /* ===== DROPDOWN TÌM KIẾM (STYLE MỚI) ===== */
        .search-dropdown {
            position: absolute;
            top: 38px;
            left: 0;
            width: 460px;
            background: white;
            border-radius: 10px;
            box-shadow: 0 4px 24px rgba(0,0,0,.15);
            z-index: 999;
            max-height: 420px;
            overflow-y: auto;
        }

        .search-item {
            display: flex;
            align-items: center;
            padding: 10px 14px;
            cursor: pointer;
            border-bottom: 1px solid #f3f4f6;
            gap: 12px;
        }

            .search-item:hover {
                background: #f0f7ff;
            }

            .search-item:last-child {
                border-bottom: none;
            }

        .sp-img {
            width: 52px;
            height: 52px;
            object-fit: cover;
            border-radius: 8px;
            border: 1px solid #eee;
            background: #f8f9fb;
            flex-shrink: 0;
        }

        .sp-img-placeholder {
            width: 52px;
            height: 52px;
            border-radius: 8px;
            border: 1px solid #eee;
            background: #f8f9fb;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ccc;
            font-size: 22px;
            flex-shrink: 0;
        }

        .sp-info {
            flex: 1;
            min-width: 0;
        }

        .sp-ten {
            font-weight: 600;
            font-size: 13.5px;
            color: #1a1a2e;
            line-height: 1.3;
        }

        .sp-mavach {
            font-size: 12px;
            color: #8a94a6;
            margin-top: 2px;
        }

        .sp-ton {
            font-size: 12px;
            color: #6b7280;
            margin-top: 2px;
        }

        .sp-gia {
            font-weight: 700;
            font-size: 15px;
            color: #1565c0;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .search-empty {
            padding: 20px;
            text-align: center;
            color: #8a94a6;
            font-size: 13px;
        }

        /* ===== MAIN LAYOUT ===== */
        .pos-main {
            display: flex;
            height: calc(100vh - 50px);
        }

        .pos-left {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .pos-right {
            width: 400px;
            background: white;
            border-left: 1px solid var(--border);
            display: flex;
            flex-direction: column;
        }

        /* ===== GIỎ HÀNG ===== */
        .cart-table-wrap {
            flex: 1;
            overflow-y: auto;
            padding: 10px;
        }

        .cart-table {
            width: 100%;
            border-collapse: collapse;
        }

            .cart-table th {
                background: #f8f9fb;
                padding: 8px 10px;
                text-align: left;
                font-size: 13px;
                color: #6b7280;
                border-bottom: 1px solid var(--border);
            }

            .cart-table td {
                padding: 8px 10px;
                border-bottom: 1px solid #f3f4f6;
                vertical-align: middle;
            }

        .qty-control {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .qty-btn {
            width: 26px;
            height: 26px;
            border: 1px solid var(--border);
            background: white;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
        }

        .qty-input {
            width: 40px;
            text-align: center;
            border: 1px solid var(--border);
            border-radius: 4px;
            padding: 2px;
        }

        .del-btn {
            border: none;
            background: none;
            color: #ef4444;
            cursor: pointer;
            font-size: 16px;
        }

        .empty-state {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #c8cfd8;
        }

            .empty-state i {
                font-size: 50px;
            }

        /* ===== ORDER SUMMARY ===== */
        .order-summary {
            padding: 14px;
            border-top: 1px solid var(--border);
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 0;
            border-bottom: 1px solid #f3f4f6;
        }

            .summary-row.total {
                font-size: 16px;
                font-weight: 700;
                color: var(--blue);
            }

        .discount-input {
            border: 1px solid var(--border);
            border-radius: 4px;
            padding: 4px 8px;
            width: 90px;
            text-align: right;
            outline: none;
        }

        .change-label {
            color: #8a94a6;
        }

        /* ===== PAYMENT ===== */
        .payment-section {
            padding: 14px;
        }

        .payment-input {
            position: relative;
            margin-bottom: 10px;
        }

            .payment-input input {
                width: 100%;
                border: 1px solid var(--border);
                border-radius: 6px;
                padding: 8px 35px 8px 10px;
                outline: none;
            }

            .payment-input span {
                position: absolute;
                right: 10px;
                top: 50%;
                transform: translateY(-50%);
                color: #999;
            }

        .checkout-btn {
            width: 100%;
            height: 48px;
            border: none;
            border-radius: 8px;
            background: var(--blue);
            color: white;
            font-weight: 700;
            cursor: pointer;
            font-size: 15px;
        }

            .checkout-btn:hover {
                background: var(--blue-dark);
            }

            .checkout-btn:disabled {
                background: #9ca3af;
                cursor: not-allowed;
            }

        /* ===== TOAST QUÉT MÃ VẠCH ===== */
        .scan-toast {
            position: fixed;
            top: 64px;
            left: 50%;
            transform: translateX(-50%);
            background: #1e293b;
            color: white;
            padding: 10px 20px;
            border-radius: 8px;
            font-size: 13.5px;
            display: flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 4px 16px rgba(0,0,0,.25);
            z-index: 9999;
            opacity: 0;
            transition: opacity .2s;
            pointer-events: none;
        }

            .scan-toast.show {
                opacity: 1;
            }

            .scan-toast.success {
                background: #166534;
            }

            .scan-toast.error {
                background: #991b1b;
            }

        /* ===== MODAL IN HÓA ĐƠN ===== */
        .print-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.55);
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .print-modal {
            background: white;
            border-radius: 12px;
            width: 420px;
            max-height: 90vh;
            display: flex;
            flex-direction: column;
            box-shadow: 0 8px 40px rgba(0,0,0,.25);
        }

        .print-modal-header {
            padding: 14px 18px;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-weight: 700;
            font-size: 15px;
        }

        .print-modal-close {
            border: none;
            background: none;
            font-size: 20px;
            cursor: pointer;
            color: #6b7280;
            line-height: 1;
        }

        .print-modal-body {
            flex: 1;
            overflow-y: auto;
            padding: 10px;
        }

        .print-modal-footer {
            padding: 12px 18px;
            border-top: 1px solid #e5e7eb;
            display: flex;
            gap: 8px;
            justify-content: flex-end;
        }

        .btn-print {
            height: 38px;
            padding: 0 20px;
            background: var(--blue);
            color: white;
            border: none;
            border-radius: 6px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 6px;
            font-family: 'Be Vietnam Pro', sans-serif;
        }

            .btn-print:hover {
                background: var(--blue-dark);
            }

        .btn-cancel-print {
            height: 38px;
            padding: 0 16px;
            background: white;
            color: #374151;
            border: 1px solid #d1d5db;
            border-radius: 6px;
            font-size: 14px;
            cursor: pointer;
            font-family: 'Be Vietnam Pro', sans-serif;
        }

        /* ===== HÓA ĐƠN IN (khổ 80mm) ===== */
        #receiptContent {
            font-family: 'Courier New', monospace;
            font-size: 12px;
            color: #111;
            background: white;
            padding: 16px;
            border: 1px dashed #d1d5db;
            border-radius: 8px;
            min-height: 200px;
        }

        .receipt-shop {
            text-align: center;
            font-size: 15px;
            font-weight: bold;
            margin-bottom: 2px;
        }

        .receipt-addr {
            text-align: center;
            font-size: 11px;
            color: #555;
            margin-bottom: 8px;
        }

        .receipt-title {
            text-align: center;
            font-size: 14px;
            font-weight: bold;
            margin: 8px 0 4px;
            letter-spacing: 1px;
        }

        .receipt-meta {
            font-size: 11px;
            margin-bottom: 8px;
            color: #444;
        }

        .receipt-divider {
            border: none;
            border-top: 1px dashed #aaa;
            margin: 6px 0;
        }

        .receipt-item-row {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            margin: 3px 0;
        }

        .receipt-item-name {
            flex: 1;
        }

        .receipt-item-qty {
            width: 30px;
            text-align: center;
        }

        .receipt-item-price {
            width: 70px;
            text-align: right;
        }

        .receipt-item-total {
            width: 80px;
            text-align: right;
            font-weight: 600;
        }

        .receipt-summary {
            font-size: 12px;
            margin-top: 4px;
        }

        .receipt-summary-row {
            display: flex;
            justify-content: space-between;
            padding: 2px 0;
        }

            .receipt-summary-row.big {
                font-size: 14px;
                font-weight: bold;
                border-top: 1px solid #aaa;
                padding-top: 4px;
                margin-top: 2px;
            }

        .receipt-footer {
            text-align: center;
            font-size: 11px;
            color: #666;
            margin-top: 10px;
        }

        @@media print {
            body > *:not(#printArea) {
                display: none !important;
            }

            #printArea {
                display: block !important;
                position: fixed;
                inset: 0;
                padding: 0;
                margin: 0;
                font-family: 'Courier New', monospace;
                font-size: 12px;
            }
        }
    </style>
</head>
<body>

    <!-- TOPBAR -->
    <nav class="pos-topbar">
        <div class="pos-search">
            <i class="bi bi-search"></i>
            <input type="text" id="searchInput" placeholder="Tìm hàng hóa (F3)" autocomplete="off" />
            <span class="kbd">F3</span>
            <div class="search-dropdown" id="searchDropdown" style="display:none;"></div>
        </div>
        <button class="icon-btn"><i class="bi bi-upc-scan"></i></button>
        <div class="topbar-right">
            <button class="nav-icon" onclick="resetCart()" title="Tạo đơn mới"><i class="bi bi-arrow-clockwise"></i></button>
            <button class="nav-icon" onclick="moModalIn()" title="In hóa đơn (F8)"><i class="bi bi-printer"></i></button>
            <span>Nhân viên</span>
            <button class="nav-icon"><i class="bi bi-list"></i></button>
        </div>
    </nav>

    <!-- MAIN -->
    <div class="pos-main">

        <!-- LEFT: Giỏ hàng -->
        <div class="pos-left">
            <div id="emptyState" class="empty-state">
                <i class="bi bi-bag-plus"></i>
                <p class="mt-2">Chưa có sản phẩm nào trong đơn hàng</p>
            </div>
            <div class="cart-table-wrap" id="cartWrap" style="display:none;">
                <table class="cart-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Tên sản phẩm</th>
                            <th>Đơn giá</th>
                            <th>Số lượng</th>
                            <th>Thành tiền</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="cartBody"></tbody>
                </table>
            </div>
        </div>

        <!-- RIGHT: Thanh toán -->
        <div class="pos-right">
            <div class="order-summary">
                <div class="summary-row">
                    <span>Tổng tiền hàng</span>
                    <span id="tongTienHang">0 ₫</span>
                </div>
                <div class="summary-row">
                    <span>Giảm giá (%)</span>
                    <input class="discount-input" type="number" id="phanTramGiam" placeholder="0" min="0" max="100" value="0" />
                </div>
                <div class="summary-row total">
                    <span>Khách cần trả</span>
                    <span id="tienSauGiam">0 ₫</span>
                </div>
                <div class="summary-row">
                    <span class="change-label">Tiền thừa trả khách</span>
                    <span id="tienThua">—</span>
                </div>
            </div>

            <div class="payment-section">
                <div class="payment-input">
                    <input type="number" id="tienKhachDua" placeholder="Nhập số tiền khách đưa" min="0" />
                    <span>₫</span>
                </div>
                <button class="checkout-btn" id="btnThanhToan" onclick="thanhToan()">
                    THANH TOÁN
                </button>
            </div>
        </div>

    </div>

    <!-- TOAST QUÉT MÃ VẠCH -->
    <div class="scan-toast" id="scanToast"></div>

    <!-- MODAL IN HÓA ĐƠN -->
    <div class="print-overlay" id="printOverlay" style="display:none">
        <div class="print-modal">
            <div class="print-modal-header">
                <span><i class="bi bi-printer me-2"></i>Xem trước hóa đơn</span>
                <button class="print-modal-close" onclick="dongModalIn()">×</button>
            </div>
            <div class="print-modal-body">
                <div id="receiptContent"></div>
            </div>
            <div class="print-modal-footer">
                <button class="btn-cancel-print" onclick="dongModalIn()">Đóng</button>
                <button class="btn-print" onclick="inHoaDon()">
                    <i class="bi bi-printer-fill"></i> In hóa đơn
                </button>
            </div>
        </div>
    </div>

    <!-- VÙNG IN ẨN -->
    <div id="printArea" style="display:none"></div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script>
        // ===== STATE =====
        let cart = [];

        // ===== ĐỊNH DẠNG TIỀN =====
        function formatMoney(n) {
            return Number(n).toLocaleString('vi-VN') + ' ₫';
        }

        // ===== TÌM SẢN PHẨM =====
        let searchTimer;
        $('#searchInput').on('input', function () {
            clearTimeout(searchTimer);
            let kw = $(this).val().trim();
            if (!kw) { $('#searchDropdown').hide(); return; }

            searchTimer = setTimeout(function () {
                $.get('/BanHang/TimSanPham', { keyword: kw }, function (data) {
                    if (!data.length) {
                        $('#searchDropdown').html('<div class="search-empty"><i class="bi bi-search me-1"></i>Không tìm thấy sản phẩm</div>').show();
                        return;
                    }
                    let html = '';
                    data.forEach(sp => {
                        // Render ảnh hoặc placeholder
                        let imgHtml = sp.HinhAnh
                            ? `<img class="sp-img" src="${sp.HinhAnh}" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"/>
                                   <div class="sp-img-placeholder" style="display:none"><i class="bi bi-image"></i></div>`
                            : `<div class="sp-img-placeholder"><i class="bi bi-image"></i></div>`;

                        // Escape tên sản phẩm tránh lỗi khi có dấu nháy
                        let tenEscaped = sp.TenSanPham.replace(/'/g, "\\'");

                        html += `<div class="search-item"
                                        onclick="addToCart(${sp.MaSanPham},'${tenEscaped}',${sp.GiaBan},${sp.SoLuong})">
                                ${imgHtml}
                                <div class="sp-info">
                                    <div class="sp-ten">${sp.TenSanPham}</div>
                                    <div class="sp-mavach">${sp.MaVach || ''}</div>
                                    <div class="sp-ton">Tồn: ${sp.SoLuong}&nbsp;&nbsp;|&nbsp;&nbsp;KH đặt: 0</div>
                                </div>
                                <div class="sp-gia">${Number(sp.GiaBan).toLocaleString('vi-VN')}</div>
                            </div>`;
                    });
                    $('#searchDropdown').html(html).show();
                });
            }, 300);
        });

        // Ẩn dropdown khi click ra ngoài
        $(document).on('click', function (e) {
            if (!$(e.target).closest('.pos-search').length)
                $('#searchDropdown').hide();
        });

        // ===== THÊM VÀO GIỎ =====
        function addToCart(maSP, tenSP, giaBan, soLuongTon) {
            $('#searchDropdown').hide();
            $('#searchInput').val('');

            let existing = cart.find(x => x.MaSanPham === maSP);
            if (existing) {
                if (existing.SoLuong >= soLuongTon) {
                    alert('Không đủ tồn kho!'); return;
                }
                existing.SoLuong++;
            } else {
                cart.push({ MaSanPham: maSP, TenSanPham: tenSP, GiaBan: giaBan, SoLuong: 1, TonKho: soLuongTon });
            }
            renderCart();
        }

        // ===== RENDER GIỎ HÀNG =====
        function renderCart() {
            if (!cart.length) {
                $('#emptyState').show();
                $('#cartWrap').hide();
                tinhToan();
                return;
            }
            $('#emptyState').hide();
            $('#cartWrap').show();

            let html = '';
            cart.forEach((item, i) => {
                let thanhTien = item.SoLuong * item.GiaBan;
                html += `<tr>
                        <td>${i + 1}</td>
                        <td>${item.TenSanPham}</td>
                        <td>${formatMoney(item.GiaBan)}</td>
                        <td>
                            <div class="qty-control">
                                <button class="qty-btn" onclick="changeQty(${i}, -1)">−</button>
                                <input class="qty-input" type="number" value="${item.SoLuong}"
                                    onchange="setQty(${i}, this.value)" min="1" max="${item.TonKho}"/>
                                <button class="qty-btn" onclick="changeQty(${i}, 1)">+</button>
                            </div>
                        </td>
                        <td><strong>${formatMoney(thanhTien)}</strong></td>
                        <td><button class="del-btn" onclick="removeItem(${i})"><i class="bi bi-trash"></i></button></td>
                    </tr>`;
            });
            $('#cartBody').html(html);
            tinhToan();
        }

        // ===== THAY ĐỔI SỐ LƯỢNG =====
        function changeQty(index, delta) {
            let item = cart[index];
            let newQty = item.SoLuong + delta;
            if (newQty < 1) { removeItem(index); return; }
            if (newQty > item.TonKho) { alert('Không đủ tồn kho!'); return; }
            item.SoLuong = newQty;
            renderCart();
        }

        function setQty(index, val) {
            let qty = parseInt(val);
            if (isNaN(qty) || qty < 1) qty = 1;
            if (qty > cart[index].TonKho) { alert('Không đủ tồn kho!'); qty = cart[index].TonKho; }
            cart[index].SoLuong = qty;
            renderCart();
        }

        function removeItem(index) {
            cart.splice(index, 1);
            renderCart();
        }

        function resetCart() {
            if (cart.length && !confirm('Bạn có chắc muốn hủy đơn hàng này?')) return;
            cart = [];
            renderCart();
            $('#phanTramGiam').val(0);
            $('#tienKhachDua').val('');
        }

        // ===== TÍNH TIỀN =====
        function tinhToan() {
            let tong = cart.reduce((s, x) => s + x.SoLuong * x.GiaBan, 0);
            let phanTram = parseFloat($('#phanTramGiam').val()) || 0;
            let tienSauGiam = tong * (1 - phanTram / 100);
            let tienKhach = parseFloat($('#tienKhachDua').val()) || 0;
            let tienThua = tienKhach - tienSauGiam;

            $('#tongTienHang').text(formatMoney(tong));
            $('#tienSauGiam').text(formatMoney(tienSauGiam));
            $('#tienThua').text(tienKhach > 0 ? formatMoney(Math.max(0, tienThua)) : '—');
        }

        $('#phanTramGiam, #tienKhachDua').on('input', tinhToan);

        // ===== THANH TOÁN =====
        function thanhToan() {
            if (!cart.length) { alert('Chưa có sản phẩm trong đơn!'); return; }

            let tong = cart.reduce((s, x) => s + x.SoLuong * x.GiaBan, 0);
            let phanTram = parseFloat($('#phanTramGiam').val()) || 0;
            let tienSauGiam = tong * (1 - phanTram / 100);
            let tienKhach = parseFloat($('#tienKhachDua').val()) || 0;

            if (tienKhach < tienSauGiam) { alert('Số tiền khách đưa chưa đủ!'); return; }

            let data = {
                PhanTramGiam: phanTram,
                TongTien: tong,
                TienSauGiam: tienSauGiam,
                TienKhachDua: tienKhach,
                ChiTiet: cart.map(x => ({
                    MaSanPham: x.MaSanPham,
                    TenSanPham: x.TenSanPham,
                    SoLuong: x.SoLuong,
                    GiaBan: x.GiaBan
                }))
            };

            $('#btnThanhToan').prop('disabled', true).text('Đang xử lý...');

            $.ajax({
                url: '/BanHang/ThanhToan',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (res) {
                    if (res.success) {
                        // Lưu cart lại để in trước khi reset
                        let cartSnapshot = JSON.parse(JSON.stringify(cart));
                        let pct = parseFloat($('#phanTramGiam').val()) || 0;
                        let tong = cartSnapshot.reduce((s, x) => s + x.SoLuong * x.GiaBan, 0);
                        let sau = tong * (1 - pct / 100);
                        let kh = parseFloat($('#tienKhachDua').val()) || 0;

                        resetCart();

                        // Mở modal in với mã đơn thật
                        document.getElementById('receiptContent').innerHTML = taoNoiDungHoaDon(res.maDon);
                        document.getElementById('printOverlay').style.display = 'flex';
                    } else {
                        alert('❌ Lỗi: ' + res.message);
                    }
                },
                error: function () {
                    alert('❌ Lỗi kết nối server!');
                },
                complete: function () {
                    $('#btnThanhToan').prop('disabled', false).text('THANH TOÁN');
                }
            });
        }

        // ===== PHÍM TẮT =====
        document.addEventListener('keydown', function (e) {
            if (e.key === 'F3') { e.preventDefault(); $('#searchInput').focus(); }
            if (e.key === 'F8') { e.preventDefault(); moModalIn(); }
        });

        // ===== TOAST =====
        let toastTimer;
        function showToast(msg, type = '') {
            let t = document.getElementById('scanToast');
            t.className = 'scan-toast show ' + type;
            t.innerHTML = (type === 'success' ? '<i class="bi bi-check-circle-fill"></i>' :
                type === 'error' ? '<i class="bi bi-x-circle-fill"></i>' :
                    '<i class="bi bi-upc-scan"></i>') + ' ' + msg;
            clearTimeout(toastTimer);
            toastTimer = setTimeout(() => t.classList.remove('show'), 2000);
        }

        // ===== MÁY QUÉT MÃ VẠCH USB =====
        // Máy quét USB hoạt động như bàn phím: gõ nhanh chuỗi ký tự rồi Enter
        // Ta bắt các ký tự gõ nhanh (< 50ms giữa các ký tự) + kết thúc bằng Enter
        let barcodeBuffer = '';
        let barcodeTimer = null;
        const BARCODE_TIMEOUT = 80; // ms — máy quét thường gõ nhanh hơn người

        document.addEventListener('keypress', function (e) {
            // Nếu đang focus vào input thường thì bỏ qua (để không can thiệp gõ tay)
            let tag = document.activeElement.tagName;
            let isInput = (tag === 'INPUT' || tag === 'TEXTAREA');

            // Nếu Enter được bấm khi buffer có dữ liệu → đây là lần quét xong
            if (e.key === 'Enter' && barcodeBuffer.length >= 3) {
                e.preventDefault();
                let code = barcodeBuffer.trim();
                barcodeBuffer = '';
                clearTimeout(barcodeTimer);

                // Nếu đang focus input search thì dùng luôn giá trị đó
                if (isInput && document.activeElement.id === 'searchInput') {
                    document.activeElement.blur();
                }

                xuLyMaVach(code);
                return;
            }

            // Tích lũy buffer nếu ký tự đến liên tục
            if (!isInput || document.activeElement.id === 'searchInput') {
                // Reset buffer nếu quá lâu giữa 2 ký tự
                clearTimeout(barcodeTimer);
                barcodeBuffer += e.key;
                barcodeTimer = setTimeout(() => { barcodeBuffer = ''; }, BARCODE_TIMEOUT * 3);
            }
        });

        function xuLyMaVach(code) {
            showToast('Đang tìm: ' + code);
            $.get('/BanHang/TimSanPham', { keyword: code }, function (data) {
                if (!data.length) {
                    showToast('Không tìm thấy mã: ' + code, 'error');
                    return;
                }
                // Nếu tìm thấy đúng 1 sản phẩm hoặc có sản phẩm khớp mã vạch chính xác
                let sp = data.find(x => x.MaVach === code) || data[0];
                addToCart(sp.MaSanPham, sp.TenSanPham, sp.GiaBan, sp.SoLuong);
                showToast('Đã thêm: ' + sp.TenSanPham, 'success');
            }).fail(() => showToast('Lỗi kết nối!', 'error'));
        }

        // ===== IN HÓA ĐƠN =====
        function taoNoiDungHoaDon(maDon) {
            let now = new Date();
            let ngay = now.toLocaleDateString('vi-VN');
            let gio = now.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
            let tong = cart.reduce((s, x) => s + x.SoLuong * x.GiaBan, 0);
            let pct = parseFloat($('#phanTramGiam').val()) || 0;
            let sau = tong * (1 - pct / 100);
            let khach = parseFloat($('#tienKhachDua').val()) || 0;
            let thua = Math.max(0, khach - sau);
            let line = '─'.repeat(36);

            let itemsHtml = '';
            cart.forEach(item => {
                let tt = item.SoLuong * item.GiaBan;
                itemsHtml += `
                    <div class="receipt-item-row">
                        <span class="receipt-item-name">${item.TenSanPham}</span>
                    </div>
                    <div class="receipt-item-row" style="color:#555;padding-left:8px">
                        <span>${item.SoLuong} x ${item.GiaBan.toLocaleString('vi-VN')}</span>
                        <span style="font-weight:600">${tt.toLocaleString('vi-VN')} ₫</span>
                    </div>`;
            });

            return `
                <div class="receipt-shop">🏪 CỬA HÀNG TẠP HÓA</div>
                <div class="receipt-addr">Địa chỉ: ___________________<br>SĐT: 0xxx xxx xxx</div>
                <hr class="receipt-divider"/>
                <div class="receipt-title">HÓA ĐƠN BÁN HÀNG</div>
                <div class="receipt-meta">
                    Mã đơn: <strong>${maDon || 'TẠM TÍNH'}</strong><br>
                    Ngày: ${ngay} &nbsp; Giờ: ${gio}<br>
                    Thu ngân: Nhân viên
                </div>
                <hr class="receipt-divider"/>
                <div style="font-size:11px;color:#666;margin-bottom:4px">Tên SP &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Thành tiền</div>
                <hr class="receipt-divider"/>
                ${itemsHtml}
                <hr class="receipt-divider"/>
                <div class="receipt-summary">
                    <div class="receipt-summary-row"><span>Tổng tiền hàng:</span><span>${tong.toLocaleString('vi-VN')} ₫</span></div>
                    ${pct > 0 ? `<div class="receipt-summary-row"><span>Giảm giá (${pct}%):</span><span>-${(tong - sau).toLocaleString('vi-VN')} ₫</span></div>` : ''}
                    <div class="receipt-summary-row big"><span>Khách phải trả:</span><span>${sau.toLocaleString('vi-VN')} ₫</span></div>
                    ${khach > 0 ? `<div class="receipt-summary-row"><span>Tiền khách đưa:</span><span>${khach.toLocaleString('vi-VN')} ₫</span></div>
                    <div class="receipt-summary-row"><span>Tiền thừa:</span><span>${thua.toLocaleString('vi-VN')} ₫</span></div>` : ''}
                </div>
                <hr class="receipt-divider"/>
                <div class="receipt-footer">
                    Cảm ơn quý khách đã mua hàng!<br>
                    Hẹn gặp lại 😊
                </div>`;
        }

        function moModalIn() {
            if (!cart.length) { showToast('Chưa có sản phẩm trong đơn!', 'error'); return; }
            document.getElementById('receiptContent').innerHTML = taoNoiDungHoaDon(null);
            document.getElementById('printOverlay').style.display = 'flex';
        }

        function dongModalIn() {
            document.getElementById('printOverlay').style.display = 'none';
        }

        function inHoaDon() {
            let content = document.getElementById('receiptContent').innerHTML;
            let printArea = document.getElementById('printArea');
            printArea.innerHTML = `<style>
                    body { font-family: 'Courier New', monospace; font-size: 12px; }
                    @@page { size: 80mm auto; margin: 4mm; }
                    .receipt-shop  { text-align:center; font-size:15px; font-weight:bold; }
                    .receipt-addr  { text-align:center; font-size:11px; color:#555; }
                    .receipt-title { text-align:center; font-size:14px; font-weight:bold; letter-spacing:1px; margin:6px 0; }
                    .receipt-meta  { font-size:11px; margin-bottom:6px; }
                    .receipt-divider { border:none; border-top:1px dashed #aaa; margin:4px 0; }
                    .receipt-item-row { display:flex; justify-content:space-between; font-size:12px; margin:2px 0; }
                    .receipt-summary-row { display:flex; justify-content:space-between; padding:2px 0; }
                    .receipt-summary-row.big { font-size:14px; font-weight:bold; border-top:1px solid #aaa; padding-top:4px; }
                    .receipt-footer { text-align:center; font-size:11px; color:#666; margin-top:8px; }
                </style>` + content;
            printArea.style.display = 'block';
            window.print();
            printArea.style.display = 'none';
        }

        // Cập nhật hóa đơn sau khi thanh toán thành công → in luôn với mã đơn thật
        function thanhToanVaIn(maDon) {
            document.getElementById('receiptContent').innerHTML = taoNoiDungHoaDon(maDon);
            document.getElementById('printOverlay').style.display = 'flex';
        }
    </script>
</body>
</html>
