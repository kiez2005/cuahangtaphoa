@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>

    <meta name="viewport" content="width=device-width" />
    <title>Trang chủ</title>

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <style>

        body {
            margin: 0;
            font-family: Arial;
        }

        /* TOP BAR */

        .topbar {
            height: 60px;
            background: white;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 10px;
        }

        .logo {
            font-size: 25px;
            font-weight: bold;
            color: #2a73cc;
        }

        .top-icons {
            display: flex;
            gap: 20px;
            margin-left: auto;
            cursor: pointer;
        }

        .top-icons i {
            margin-right: 5px;
            color: #2a73cc;
        }

        .user-menu {
            position: relative;
        }

        .user-icon {
            background: #e5edf8;
            padding: 10px;
            border-radius: 50%;
            cursor: pointer;
            margin-left: 15px;
        }

        .dropdown-menu {
            position: absolute;
            right: 0;
            top: 50px;
            width: 220px;
            background: white;
            border-radius: 10px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.2);
            display: none;
        }

        .menu-item {
            padding: 12px;
            border-bottom: 1px solid #eee;
        }

        .menu-item:last-child {
            border-bottom: none;
         }

        .menu-item:hover {
            background: #f5f5f5;
        }

        .menu-item a {
            text-decoration: none;
            color: black;
        }    

        /* NAVBAR */

        .navbar {
            background: #1e73d8;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
        }

        .menu {
            display: flex;
            gap: 25px;
        }

        .menu a {
            color: white;
            text-decoration: none;
            padding: 8px 12px;
            border-radius: 6px;
            cursor: pointer;
        }

        .menu a:hover {
            background: #0f5ec4;
        }

        .menu .active {
            background: #0f5ec4;
        }

        .sell-btn {
            background: white;
            border: none;
            padding: 10px 18px;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
            font-size: 15px;
        }

        .sell-btn i {
            color: #1e73d8;
        }

        .content {
            padding: 30px;
        }
    </style>

</head>


<script>

    function toggleMenu() {

        var menu = document.getElementById("dropdown");

        if (menu.style.display === "block") {
            menu.style.display = "none";
        } else {
            menu.style.display = "block";
        }

    }

</script>

<body>

    <!-- TOP BAR -->

    <div class="topbar">

        <div class="logo">
            <i class="fa-solid fa-store"></i> KiotViet
        </div>

        <div class="top-icons">

            <span><i class="fa-solid fa-truck"></i> Giao hàng</span>

            <span><i class="fa-solid fa-palette"></i> Chủ đề</span>

            <span><i class="fa-solid fa-circle-question"></i> Hỗ trợ</span>

            <span><i class="fa-solid fa-comment"></i> Góp ý</span>

        </div>

        <div class="user-menu">

            <div class="user-icon" onclick="toggleMenu()">
                <i class="fa-solid fa-user"></i>
            </div>

            <div id="dropdown" class="dropdown-menu">

                <div class="menu-item">
                    <b>0815958918</b><br>
                    <span style="color:red">Chưa bật xác thực 2 lớp</span>
                </div>

                <div class="menu-item">
                    <a href="/Login/Logout">Đăng xuất</a>
                </div>

            </div>

        </div>

    </div>

    <!-- NAVBAR -->

    <div class="navbar">

        <div class="menu">

            <a class="active">Tổng quan</a>
            <a>Hàng hóa</a>
            <a>Đơn hàng</a>
            <a>Khách hàng</a>
            <a>Nhân viên</a>
            <a>Sổ quỹ</a>
            <a>Báo cáo</a>
            <a>Bán online</a>
            <a>Thuế & Kế toán</a>

        </div>

        <button class="sell-btn">
            <i class="fa-solid fa-cart-shopping"></i> Bán hàng
        </button>

    </div>
 

</body>
</html>