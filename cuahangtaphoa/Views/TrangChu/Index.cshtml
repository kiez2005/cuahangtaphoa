    <!-- MODAL SẮP HẾT HÀNG -->
    <div id="modalSapHet" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1000;align-items:center;justify-content:center;">
        <div class="modal-box">
            <div class="modal-header">
                <span style="font-size:15px;font-weight:700;color:var(--red)">
                    <i class="bi bi-exclamation-triangle me-2"></i>Sản phẩm sắp hết / hết hàng
                </span>
                <button class="modal-close" onclick="dongModalSapHet()">×</button>
            </div>
            <div class="modal-body" id="sapHetBody">
                <div class="empty-box">
                    <div class="empty-box-icon"><i class="bi bi-hourglass-split"></i></div>
                    <span>Đang tải...</span>
                </div>
            </div>
            <div class="modal-footer">
                <button onclick="dongModalSapHet()"
                        style="height:34px;padding:0 16px;border:1px solid var(--border);border-radius:6px;background:white;cursor:pointer;font-family:'Be Vietnam Pro',sans-serif;font-size:13px">
                    Đóng
                </button>
                <a href="/HangHoa"
                   style="height:34px;padding:0 16px;border:none;border-radius:6px;background:var(--blue);color:white;font-size:13px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:6px;text-decoration:none">
                    <i class="bi bi-box-seam"></i> Quản lý hàng hóa
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script>
        let revenueChart;

        /* ── CHART ─────────────────────────────────────── */
        function initChart(labels, data) {
            const ctx = document.getElementById('revenueChart').getContext('2d');
            if (revenueChart) revenueChart.destroy();
            revenueChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels,
                    datasets: [{
                        data,
                        borderColor: '#4285f4',
                        backgroundColor: 'rgba(66,133,244,.08)',
                        borderWidth: 2,
                        pointRadius: 3,
                        pointBackgroundColor: '#4285f4',
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: {
                            grid: { color: '#f0f0f0' },
                            ticks: { font: { size: 11, family: 'Be Vietnam Pro' }, color: '#9e9e9e', maxTicksLimit: 10 }
                        },
                        y: {
                            grid: { color: '#f0f0f0' },
                            beginAtZero: true,
                            ticks: {
                                font: { size: 11, family: 'Be Vietnam Pro' },
                                color: '#9e9e9e',
                                callback: v => v === 0 ? '0' : v >= 1000000 ? (v / 1000000).toFixed(0) + 'tr' : v >= 1000 ? (v / 1000).toFixed(0) + 'k' : v
                            }
                        }
                    }
                }
            }
        });
    }

    function loadStats() {
        $.get('/Dashboard/GetStats', function (res) {
            if (!res.success) { $('#statDoanhThu,#statHoaDon,#statSapHet').text('—'); return; }
            $('#statDoanhThu').text(res.doanhThuText);
            $('#statTraHang').text(res.traHang);
            $('#statHoaDon').text(res.soHoaDon);
            $('#statSapHet').text(res.sapHet > 0 ? res.sapHet : '0');
            if (res.sapHet > 0) {
                $('#noticeText').html('<span style="color:var(--red);font-weight:600;cursor:pointer" onclick="moModalSapHet()">⚠ ' + res.sapHet + ' sản phẩm sắp hết hàng — Click để xem</span>');
            }
        }).fail(() => $('#statDoanhThu,#statHoaDon,#statSapHet').text('—'));
    }

    function loadChart() {
        $.get('/Dashboard/GetDoanhThu', { filter: $('#filterChart').val() }, function (res) {
            if (!res.success) return;
            $('#tongDoanhThu').text(res.tongDoanhThuText);
            initChart(res.labels, res.data);
        });
    }

    function switchTab(el) {
        document.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));
        el.classList.add('active');
        loadChart();
    }

    function loadTopSanPham() {
        let sortBy = $('#sortTopSP').val() || 'revenue';
        let filter = $('#filterChart').val() || 'month';
        $('#topSanPhamList').html('<div class="empty-box"><div class="empty-box-icon"><i class="bi bi-hourglass-split"></i></div><span>Đang tải...</span></div>');
        $.get('/Dashboard/GetTopSanPham', { sortBy, filter }, function (res) {
            if (!res.success || !res.data.length) {
                $('#topSanPhamList').html('<div class="empty-box"><div class="empty-box-icon"><i class="bi bi-inbox"></i></div><span>Chưa có dữ liệu</span></div>');
                return;
            }
            let html = '';
            res.data.forEach((sp, i) => {
                let rc = i === 0 ? 'gold' : i === 1 ? 'silver' : i === 2 ? 'bronze' : '';
                let val = sortBy === 'quantity'
                    ? '<div class="top-val">' + sp.TongSoLuong + ' cái</div>'
                    : '<div><div class="top-val">' + Number(sp.TongDoanhThu).toLocaleString('vi-VN') + ' ₫</div><div class="top-sub">' + sp.TongSoLuong + ' cái</div></div>';
                html += '<li><div class="top-rank ' + rc + '">' + (i + 1) + '</div><div class="top-name" title="' + sp.TenSanPham + '">' + sp.TenSanPham + '</div>' + val + '</li>';
            });
            $('#topSanPhamList').html(html);
        }).fail(() => $('#topSanPhamList').html('<div class="empty-box"><div class="empty-box-icon"><i class="bi bi-exclamation-circle"></i></div><span>Lỗi tải</span></div>'));
    }

    function loadTopKhachHang() {
        let filter = $('#filterTopKH').val() || 'month';
        $('#topKhachHangList').html('<div class="empty-box"><div class="empty-box-icon"><i class="bi bi-hourglass-split"></i></div><span>Đang tải...</span></div>');
        $.get('/Dashboard/GetTopKhachHang', { filter }, function (res) {
            if (!res.success || !res.data.length) {
                $('#topKhachHangList').html('<div class="empty-box"><div class="empty-box-icon"><i class="bi bi-inbox"></i></div><span>Chưa có dữ liệu</span></div>');
                return;
            }
            let html = '';
            res.data.forEach((kh, i) => {
                let rc = i === 0 ? 'gold' : i === 1 ? 'silver' : i === 2 ? 'bronze' : '';
                html += '<li><div class="top-rank ' + rc + '">' + (i + 1) + '</div><div class="top-name" title="' + kh.HoTen + '">' + kh.HoTen + '</div><div><div class="top-val">' + kh.TongDoanhThuText + '</div><div class="top-sub">' + kh.SoHoaDon + ' đơn</div></div></li>';
            });
            $('#topKhachHangList').html(html);
        }).fail(() => $('#topKhachHangList').html('<div class="empty-box"><div class="empty-box-icon"><i class="bi bi-exclamation-circle"></i></div><span>Lỗi tải</span></div>'));
    }

    function moModalSapHet() {
        $('#modalSapHet').css('display', 'flex');
        $('#sapHetBody').html('<div class="empty-box"><div class="empty-box-icon"><i class="bi bi-hourglass-split"></i></div><span>Đang tải...</span></div>');
        $.get('/Dashboard/GetSapHetHang', function (res) {
            if (!res.success || !res.data.length) {
                $('#sapHetBody').html('<div class="empty-box"><div class="empty-box-icon"><i class="bi bi-check-circle" style="color:var(--green)"></i></div><span style="color:var(--green)">Tất cả sản phẩm còn đủ hàng!</span></div>');
                return;
            }
            let html = '';
            res.data.forEach(sp => {
                let isHet = sp.trangThai === 'het';
                let cls = isHet ? 'het' : 'sap';
                let label = isHet ? 'Hết hàng' : 'Sắp hết';
                let icon = isHet ? 'bi-x-circle-fill' : 'bi-exclamation-triangle-fill';
                html += '<div class="saphet-item"><div class="saphet-info"><div class="saphet-ten">' + sp.tenSanPham + '</div><div class="saphet-meta">'
                    + (sp.maVach ? '<span style="background:#f1f3f4;padding:1px 6px;border-radius:4px;font-size:11px;margin-right:6px">' + sp.maVach + '</span>' : '')
                    + (sp.danhMuc !== '—' ? '<span style="color:var(--blue-mid)">' + sp.danhMuc + '</span>' : '')
                    + ' &nbsp;·&nbsp; Giá bán: <strong>' + Number(sp.giaBan).toLocaleString('vi-VN') + ' ₫</strong>'
                    + ' &nbsp;·&nbsp; Tối thiểu: <strong>' + sp.soLuongToiThieu + '</strong>'
                    + '</div></div><div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0">'
                    + '<div class="saphet-soluong ' + cls + '">' + sp.soLuong + '</div>'
                    + '<span class="saphet-badge ' + cls + '"><i class="bi ' + icon + '"></i> ' + label + '</span>'
                    + '</div></div>';
            });
            $('#sapHetBody').html(html);
        });
    }

    function dongModalSapHet() { $('#modalSapHet').css('display', 'none'); }

    function loadActivity() {
        $('#activityList').html('<div style="padding:20px;text-align:center;color:#bbb;font-size:12px;">Đang tải...</div>');
        $.get('/Dashboard/GetHoatDong', function (res) {
            if (!res.success || !res.data.length) {
                $('#activityList').html('<div style="padding:20px;text-align:center;color:#bbb;font-size:12px;">Chưa có hoạt động</div>');
                $('#actBadge').text('0'); return;
            }
            let html = '';
            res.data.forEach(a => {
                let isBan = a.hanhDong.includes('bán');
                let icon = isBan ? 'bi-bag-check' : 'bi-box-arrow-in-down';
                let color = isBan ? '#1565c0' : '#2e7d32';
                html += '<div class="activity-item"><div class="act-icon" style="color:' + color + '"><i class="bi ' + icon + '"></i></div>'
                    + '<div><div class="act-text"><a href="#">' + a.nguoiDung + '</a> vừa <a href="#">' + a.hanhDong + '</a> — <strong>' + a.giaTri + ' ₫</strong></div>'
                    + '<div class="act-time">' + a.thoiGian + '</div></div></div>';
            });
            $('#activityList').html(html);
            $('#actBadge').text(res.total);
        }).fail(() => $('#activityList').html('<div style="padding:20px;text-align:center;color:#bbb;font-size:12px;">Lỗi tải</div>'));
    }

    function loadAll() {
        loadStats();
        loadChart();
        setTimeout(function () { loadTopSanPham(); loadTopKhachHang(); }, 100);
        loadActivity();
    }

    setInterval(loadAll, 60000);
    $(function () { loadAll(); });

    document.getElementById('modalSapHet').addEventListener('click', function (e) {
        if (e.target === this) dongModalSapHet();
    });
