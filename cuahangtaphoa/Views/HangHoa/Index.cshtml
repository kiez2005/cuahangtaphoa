@model List<cuahangtaphoa.Models.SanPham>
@{
    Layout = "~/Views/Layout/index.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">

<div class="container mt-4">

    <h3 class="mb-4">Danh sách sản phẩm</h3>

    <div class="d-flex justify-content-between align-items-center mb-3">

        <form method="get" class="row g-2 flex-grow-1">

            <!-- search -->
            <div class="col-md-3">
                <input type="text" name="search"
                       class="form-control"
                       placeholder="🔍 Tìm sản phẩm..."
                       value="@Request["search"]">
            </div>

            <!-- danh mục -->
            <div class="col-md-3">
                @Html.DropDownList("maDanhMuc",
                    ViewBag.MaDanhMuc as SelectList,
                    "-- Tất cả danh mục --",
                    new { @class = "form-select" })
            </div>

            <!-- sort -->
            <div class="col-md-3">
                <select name="sort" class="form-select">
                    <option value="">-- Sắp xếp --</option>
                    <option value="ten" @(Request["sort"] == "ten" ? "selected" : "")>Tên A-Z</option>
                    <option value="gia_asc" @(Request["sort"] == "gia_asc" ? "selected" : "")>Giá tăng</option>
                    <option value="gia_desc" @(Request["sort"] == "gia_desc" ? "selected" : "")>Giá giảm</option>
                </select>
            </div>

            <!-- reset -->
            <div class="col-md-1">
                <a href="/HangHoa/Index" class="btn btn-secondary w-100">↺</a>
            </div>

        </form>

        <!-- nút thêm -->
        <button class="btn btn-primary ms-3"
                data-bs-toggle="modal"
                data-bs-target="#modalSanPham">
            <i class="bi bi-plus-circle"></i> Thêm mới
        </button>

    </div>

    <table class="table table-bordered table-hover">

        <thead class="table-light">
            <tr>
                <th>Ảnh</th>
                <th>Mã SP</th>
                <th>Tên sản phẩm</th>
                <th>Mã vạch</th>
                <th>Giá nhập</th>
                <th style="width:140px">Giá bán</th>
                <th>Số lượng</th>
                <th>Hạn sử dụng</th>
                <th>Ngày tạo</th>
                <th>Chức năng</th>
            </tr>
        </thead>

        <tbody>

            @if (Model != null)
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(item.HinhAnh))
                            {
                                <img src="@item.HinhAnh" style="width:60px;height:60px;object-fit:cover" />
                            }
                            else
                            {
                                <span>Không có</span>
                            }
                        </td>

                        <td>@item.MaSanPham</td>
                        <td>@item.TenSanPham</td>
                        <td>@item.MaVach</td>

                        <td>@String.Format("{0:N0}", item.GiaNhap) ₫</td>

                        <td style="font-weight:bold;color:red">
                            @String.Format("{0:N0}", item.GiaBan) ₫
                        </td>

                        <td>@item.SoLuong</td>
                        <td>@(item.HanSuDung?.ToString("dd/MM/yyyy"))</td>
                        <td>@(item.NgayTao?.ToString("dd/MM/yyyy"))</td>

                        <td>
                            @if (item.SoLuong <= item.SoLuongToiThieu)
                            {
                                <span style="color:red">⚠ Tồn kho thấp</span>
                            }
                            else
                            {
                                <span style="color:green">OK</span>
                            }
                        </td>

                        <td>@(item.HanSuDung?.ToString("dd/MM/yyyy"))</td>
                        <td>@(item.NgayTao?.ToString("dd/MM/yyyy"))</td>

                        <td>
                            <button class="btn btn-warning btn-sm"
                                    data-id="@item.MaSanPham"
                                    data-ten="@item.TenSanPham"
                                    data-mavach="@item.MaVach"
                                    data-gianhap="@item.GiaNhap"
                                    data-giaban="@item.GiaBan"
                                    data-soluong="@item.SoLuong"
                                    data-hansudung="@item.HanSuDung?.ToString(" yyyy-MM-dd")"
                                    data-madanhmuc="@item.MaDanhMuc"
                                    data-mancc="@item.MaNhaCungCap"
                                    onclick="openEditModal(this)">
                                <i class="bi bi-pencil"></i> Sửa
                            </button>

                            <a href="@Url.Action("Delete","HangHoa", new { id = item.MaSanPham })"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Bạn có chắc muốn xóa?')">
                                <i class="bi bi-trash"></i> Xóa
                            </a>

                            <button class="btn btn-info btn-sm"
                                    data-id="@item.MaSanPham"
                                    data-ten="@item.TenSanPham"
                                    data-gianhap="@item.GiaNhap"
                                    data-giaban="@item.GiaBan"
                                    onclick="openPriceModal(this)">
                                <i class="bi bi-cash-stack"></i> Giá
                                Giá
                            </button>

                            <button class="btn btn-secondary btn-sm"
                                    data-ten="@item.TenSanPham"
                                    data-mavach="@item.MaVach"
                                    data-giaban="@item.GiaBan.ToString()"
                                    onclick="openBarcodeModal(this)">
                                <i class="bi bi-barcode"></i> Barcode
                                Barcode
                            </button>
                        </td>
                    </tr>
                }
            }

        </tbody>

    </table>

</div>

<!-- MODAL THÊM -->
<div class="modal fade" id="modalSanPham">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Tạo hàng hóa</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form action="/HangHoa/Create" method="post">
            <form action="/HangHoa/Create" method="post" enctype="multipart/form-data">

                <div class="modal-body">

                    <div class="row">
                        <div class="col-md-6">
                            <label>Tên sản phẩm</label>
                            <input type="text" name="TenSanPham" class="form-control" required>
                        </div>

                        <div class="col-md-6">
                            <label>Mã vạch</label>
                            <input type="text" name="MaVach" class="form-control">
                        </div>
                    </div>

                    <br>

                    <div class="row">

                        <div class="col-md-6">
                            <label>Giá nhập</label>
                            <input type="number" name="GiaNhap" class="form-control">
                        </div>

                        <div class="col-md-6">
                            <label>Giá bán</label>
                            <input type="number" name="GiaBan" class="form-control">
                        </div>

                    </div>

                    <br>

                    <div class="row">

                        <div class="col-md-6">
                            <label>Số lượng</label>
                            <input type="number" name="SoLuong" class="form-control">
                        </div>

                        <div class="col-md-6">
                            <label>Số lượng tối thiểu</label>
                            <input type="number" name="SoLuongToiThieu" class="form-control">
                        </div>

                        <div class="col-md-6 mt-3">
                            <label>Hạn sử dụng</label>
                            <input type="date" name="HanSuDung" class="form-control">
                        </div>
                        <div class="col-md-6 mt-3">
                            <label>Hình ảnh</label>
                            <input type="file" name="fileAnh" class="form-control">
                        </div>
                        <div class="row mt-3">

                            <div class="col-md-6">
                                <label>Danh mục</label>
                                @Html.DropDownList("MaDanhMuc", ViewBag.MaDanhMuc as SelectList, "-- Chọn danh mục --", new { @class = "form-select" })
                                @Html.DropDownList("MaDanhMuc", ViewBag.MaDanhMuc as SelectList, "-- Chọn danh mục --", new { @class = "form-control" })
                            </div>

                            <div class="col-md-6">
                                <label>Nhà cung cấp</label>
                                @Html.DropDownList("MaNhaCungCap", ViewBag.MaNhaCungCap as SelectList, "-- Chọn NCC --", new { @class = "form-select" })
                                @Html.DropDownList("MaNhaCungCap", ViewBag.MaNhaCungCap as SelectList, "-- Chọn NCC --", new { @class = "form-control" })
                            </div>

                        </div>

                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Bỏ qua</button>
                    <button type="submit" class="btn btn-primary">Lưu</button>
                </div>
            </form>

        </div>
    </div>
</div>

<!-- MODAL SỬA -->
<div class="modal fade" id="modalEdit">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Sửa sản phẩm</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form action="/HangHoa/Edit" method="post">

            <form action="/HangHoa/Edit" method="post" enctype="multipart/form-data">
                <div class="modal-body">

                    <input type="hidden" id="editMaSanPham" name="MaSanPham">

                    <div class="mb-3">
                        <label>Tên sản phẩm</label>
                        <input type="text" id="editTenSanPham" name="TenSanPham" class="form-control">
                    </div>

                    <div class="mb-3">
                        <label>Mã vạch</label>
                        <input type="text" id="editMaVach" name="MaVach" class="form-control">
                    </div>

                    <div class="mb-3">
                        <label>Giá nhập</label>
                        <input type="number" id="editGiaNhap" name="GiaNhap" class="form-control">
                    </div>

                    <div class="mb-3">
                        <label>Giá bán</label>
                        <input type="number" id="editGiaBan" name="GiaBan" class="form-control">
                    </div>

                    <div class="mb-3">
                        <label>Số lượng</label>
                        <input type="number" id="editSoLuong" name="SoLuong" class="form-control">
                    </div>

                    <div class="mb-3">
                        <label>Hạn sử dụng</label>
                        <input type="date" id="editHanSuDung" name="HanSuDung" class="form-control">
                    </div>
                    <div class="mb-3">
                        <label>Hình ảnh</label>
                        <input type="file" name="fileAnh" class="form-control">
                    </div>
                    <div class="mb-3">
                        <label>Danh mục</label>
                        @Html.DropDownList("MaDanhMuc",
                            ViewBag.MaDanhMuc as SelectList,
                            "-- Chọn danh mục --",
                            new { @class = "form-select", id = "editMaDanhMuc" })
                            new { @class = "form-control", id = "editMaDanhMuc" })
                    </div>

                    <div class="mb-3">
                        <label>Nhà cung cấp</label>
                        @Html.DropDownList("MaNhaCungCap",
                            ViewBag.MaNhaCungCap as SelectList,
                            "-- Chọn NCC --",
                            new { @class = "form-select", id = "editMaNhaCungCap" })
                            new { @class = "form-control", id = "editMaNhaCungCap" })
                    </div>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success">Cập nhật</button>
                </div>

            </form>

        </div>
    </div>
</div>

<!-- MODAL THIẾT LẬP GIÁ -->
<div class="modal fade" id="modalPrice">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Thiết lập giá</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form action="/HangHoa/SetPrice" method="post">

                <div class="modal-body">

                    <input type="hidden" id="priceMaSanPham" name="id">

                    <div class="mb-3">
                        <label>Tên sản phẩm</label>
                        <input type="text" id="priceTenSanPham" readonly class="form-control">
                    </div>

                    <div class="mb-3">
                        <label>Giá nhập</label>
                        <input type="number" id="priceGiaNhap" name="GiaNhap" class="form-control">
                    </div>

                    <div class="mb-3">
                        <label>Giá bán</label>
                        <input type="number" id="priceGiaBan" name="GiaBan" class="form-control">
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button class="btn btn-success">Lưu</button>
                </div>

            </form>

        </div>
    </div>
</div>

<!-- MODAL BARCODE -->
<div class="modal fade" id="modalBarcode">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">In tem mã</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body text-center">

                <h5 id="barcodeTen"></h5>

                <img id="barcodeImg" style="width:200px">

                <h4 style="color:red;margin-top:10px" id="barcodeGia"></h4>

            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button class="btn btn-success" onclick="window.print()">In</button>
            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    function openEditModal(btn) {
        var id = btn.dataset.id;
        var ten = btn.dataset.ten;
        var mavach = btn.dataset.mavach;
        var gianhap = btn.dataset.gianhap;
        var giaban = btn.dataset.giaban;
        var soluong = btn.dataset.soluong;
        var hansudung = btn.dataset.hansudung;

        document.getElementById("editMaSanPham").value = id;
        document.getElementById("editTenSanPham").value = ten;
        document.getElementById("editMaVach").value = mavach;
        document.getElementById("editGiaNhap").value = gianhap;
        document.getElementById("editGiaBan").value = giaban;
        document.getElementById("editSoLuong").value = soluong;
        document.getElementById("editMaDanhMuc").value = btn.dataset.madanhmuc;
        document.getElementById("editMaNhaCungCap").value = btn.dataset.mancc;

        if (hansudung) {
            document.getElementById("editHanSuDung").value = hansudung.split('T')[0];
        }

        var modal = new bootstrap.Modal(document.getElementById('modalEdit'));
        modal.show();
    }

    function openPriceModal(btn) {
        document.getElementById("priceMaSanPham").value = btn.dataset.id;
        document.getElementById("priceTenSanPham").value = btn.dataset.ten;
        document.getElementById("priceGiaNhap").value = btn.dataset.gianhap;
        document.getElementById("priceGiaBan").value = btn.dataset.giaban;

        var modal = new bootstrap.Modal(document.getElementById('modalPrice'));
        modal.show();
    }

    function openBarcodeModal(btn) {
        var ten = btn.getAttribute("data-ten");
        var mavach = btn.getAttribute("data-mavach");
        var giaban = parseFloat(btn.getAttribute("data-giaban"));

        if (isNaN(giaban)) {
            giaban = 0;
        }

        document.getElementById("barcodeTen").innerText = ten;

        document.getElementById("barcodeImg").src =
            "https://barcode.tec-it.com/barcode.ashx?data=" + mavach + "&code=Code128";

        document.getElementById("barcodeGia").innerText =
            giaban.toLocaleString('vi-VN') + " ₫";

        var modal = new bootstrap.Modal(document.getElementById('modalBarcode'));
        modal.show();
    }
</script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var danhMuc = document.querySelector("select[name='maDanhMuc']");
        if (danhMuc) {
            danhMuc.addEventListener("change", function () {
                this.form.submit();
            });
        }
        var sort = document.querySelector("select[name='sort']");
        if (sort) {
            sort.addEventListener("change", function () {
                this.form.submit();
            });
        }
    });
</script>
</script>
